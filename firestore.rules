rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasVerifiedEmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email_verified == true;
    }

    function currentEmail() {
      return request.auth.token.email.lower();
    }

    function accessPath(email) {
      return /databases/$(database)/documents/manureAccess/$(email);
    }

    function currentAccessExists() {
      return hasVerifiedEmail()
        && exists(accessPath(currentEmail()));
    }

    function currentAccess() {
      return get(accessPath(currentEmail())).data;
    }

    function isAllowlisted() {
      return currentAccessExists()
        && currentAccess().enabled == true;
    }

    function isAdmin() {
      return isAllowlisted()
        && currentAccess().admin == true;
    }

    function isSelfAccessRecord(email) {
      return hasVerifiedEmail()
        && currentEmail() == email;
    }

    match /manureAccess/{email} {
      allow get: if isSelfAccessRecord(email) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /manureYears/{year} {
      allow read, write: if isAllowlisted();

      match /{document=**} {
        allow read, write: if isAllowlisted();
      }
    }

    match /manureMeta/{document} {
      allow read: if isAllowlisted();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
