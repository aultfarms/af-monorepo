{
  "name": "@aultfarms/field-work",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "description": "Browser-based library for field work records backed by Trello",
  "main": "dist/index.mjs",
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:tsc": "tsc -b",
    "build:rollup": "rollup --config=rollup.config.js",
    "build": "yarn build:tsc && yarn build:rollup",
    "dev:tsc": "tsc -b -w",
    "dev:rollup": "rollup --config rollup.config.js --watch",
    "dev": "yarn run build:tsc && concurrently \"yarn run dev:tsc\" \"yarn run dev:rollup\"",
    "clean": "rm -rf dist"
  },
  "author": "Aaron Ault <aultac@gmail.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.1",
    "@yarnpkg/sdks": "^3.0.0-rc.42",
    "concurrently": "^8.0.1",
    "rollup": "^3.20.2",
    "rollup-plugin-pnp-resolve": "^2.0.0",
    "terser": "^5.16.8",
    "typescript": "^5.0.3"
  },
  "dependencies": {
    "@aultfarms/trello": "workspace:^",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@tsconfig/node16": "^1.0.3",
    "@turf/area": "^7.2.0",
    "@types/debug": "^4.1.7",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^17.0.14",
    "debug": "^4.3.4",
    "tslib": "^2.5.0",
    "yaml": "^2.8.1"
  }
}
